# Bugzilla Configuration
BUGZILLA_URL=bugzilla.mozilla.org
BUGZILLA_API_KEY=your_bugzilla_api_key_here

# Jira Configuration
JIRA_URL=https://mozilla-hub.atlassian.net
JIRA_API_USER=your_email@mozilla.com
JIRA_API_KEY=your_jira_api_key_here
# Optional: pre-migration Jira host; see_also links using it are treated as
# aliases of JIRA_URL (keys were preserved). Set empty to disable.
JIRA_LEGACY_URL=https://jira.mozilla.com

# Mozilla People Directory (optional — enables automatic Bugzilla→LDAP email lookup)
# Obtain a Bearer token from https://people.mozilla.org
PEOPLE_API_TOKEN=your_people_api_token_here
